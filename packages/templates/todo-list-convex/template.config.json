{
  "id": "todo-list-convex",
  "version": "1.0.0",
  "name": "todo-list-convex",
  "displayName": "To-Do List (Convex)",
  "category": "Productivity",
  "description": "Tenant-isolated reactive todo list backed by Appio Sandbox Convex. Proves out the Convex + Firebase auth + tenant isolation pattern established in T2.1.",
  "components": [
    "TaskList",
    "TaskInput",
    "TaskItem"
  ],
  "layouts": ["stack"],
  "dataModel": {
    "task": {
      "_id": "Id<'tasks'>",
      "tenantId": "string",
      "title": "string",
      "completed": "boolean",
      "createdAt": "number"
    }
  },
  "persona": "minimal-mono",
  "defaultTheme": {
    "primary": "#6366f1",
    "primaryLight": "#818cf8",
    "background": "#f8fafc",
    "surface": "#ffffff",
    "textPrimary": "#0f172a",
    "textSecondary": "#64748b"
  },
  "constraints": {
    "maxPages": 1,
    "maxComponentsPerPage": 4,
    "storageBackend": "convex"
  }
}
