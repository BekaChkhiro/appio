# API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_ENV=development

# Dev flags
# NEXT_PUBLIC_USE_MOCK=true — ONLY for offline local dev. Never set in staging/prod.
NEXT_PUBLIC_USE_MOCK=false

# Firebase Web SDK (required for authentication)
# Grab these from Firebase Console → Project settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Observability (optional — leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Toggle strict CSP (drops 'unsafe-inline' / 'unsafe-eval') once validated in prod
# NEXT_PUBLIC_ENABLE_STRICT_CSP=1
