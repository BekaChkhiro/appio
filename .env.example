# Database — Neon PostgreSQL
# Pooler endpoint for app queries (use -pooler hostname, prepared_statement_cache_size=0)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/appio?sslmode=require
# Direct endpoint for Alembic migrations (supports prepared statements)
DATABASE_DIRECT_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/appio?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Firebase
FIREBASE_PROJECT_ID=appio-prod
FIREBASE_SERVICE_ACCOUNT_PATH=  # Path to service-account.json; leave empty for ADC

# Firebase (Web SDK — used by apps/web and packages/auth)
NEXT_PUBLIC_FIREBASE_API_KEY=xxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=appio-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=appio-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=appio-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xxx
NEXT_PUBLIC_FIREBASE_APP_ID=xxx

# Firebase (Mobile — used by Expo)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com

# Appio sandbox Convex (T2.1) — values from packages/templates/base/.env.local
# after running `npx convex dev --once`. Shared across all preview/draft apps;
# tenant isolation enforced at the query layer (see ADR 001).
APPIO_SANDBOX_CONVEX_URL=https://adventurous-corgi-465.eu-west-1.convex.cloud
APPIO_SANDBOX_CONVEX_SITE_URL=https://adventurous-corgi-465.eu-west-1.convex.site
APPIO_SANDBOX_CONVEX_DEPLOYMENT=dev:adventurous-corgi-465

# T3.9 — Scratch-deployment data migration (Convex Management API)
# Team Access Token generated at dashboard.convex.dev/team/settings/access-tokens
# Optional in dev (tests use a fake client); required in prod.
CONVEX_PLATFORM_ACCESS_TOKEN=

# Integer project ID for a dedicated "scratch host" project in the Appio
# Convex team. Create it manually at dashboard.convex.dev (any name works);
# the ID is visible in the project URL. All ephemeral scratch deployments
# land in this project.
CONVEX_SCRATCH_HOST_PROJECT_ID=

# Deploy key for the Appio sandbox deployment itself (distinct from user
# app deploy keys). Used by the publish pipeline to call sandbox-side
# internal functions. Generate via: Convex dashboard → sandbox project →
# Settings → Deploy Keys → Generate Production Deploy Key.
APPIO_SANDBOX_DEPLOY_KEY=

# Cloudflare
CLOUDFLARE_R2_BUCKET=appio-pwas
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_R2_ACCESS_KEY=xxx
CLOUDFLARE_R2_SECRET_KEY=xxx

# Transactional Email (Resend)
RESEND_API_KEY=

# Stripe billing
STRIPE_API_KEY=sk_test_xxx                 # Secret key from Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_xxx            # Endpoint signing secret (stripe listen / dashboard)
STRIPE_PRICE_PRO=price_xxx                 # Stripe Price ID for Pro subscription
STRIPE_PRICE_CREATOR=price_xxx             # Stripe Price ID for Creator subscription

# Voyage AI — embeddings for RAG knowledge base
VOYAGE_API_KEY=pa-xxx

# RAG feature flag (set to false to disable RAG in agent loop)
AGENT_RAG_ENABLED=true

# Sentry
SENTRY_DSN=
